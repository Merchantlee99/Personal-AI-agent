# Public UI values
NEXT_PUBLIC_DASHBOARD_TITLE="Nanoclaw Air-Gapped Agent Dashboard"
NEXT_PUBLIC_DEFAULT_AGENT_ID="owl"

# Proxy router behavior: store | forward
PROXY_MODE="store"

# SQLite DB path (relative to project root unless absolute)
SQLITE_PATH="./shared_data/agent_router.db"

# n8n webhook URLs
# - INTERNAL: used by containers (llm-proxy -> n8n)
# - HOST: used by host processes (Next.js server route -> n8n)
N8N_WEBHOOK_URL_INTERNAL="http://n8n:5678/webhook/hermes-trend"
N8N_WEBHOOK_URL_HOST="http://localhost:5678/webhook/hermes-trend"
# Backward compatibility fallback
N8N_WEBHOOK_URL="http://localhost:5678/webhook/hermes-trend"
N8N_WEBHOOK_AUTH_TOKEN=""
# Optional: local n8n trend workflow key (used by n8n HTTP Request node)
TAVILY_API_KEY="tvly-your-key"

# LLM API Keys (llm-proxy 컨테이너에서 사용)
OPENAI_API_KEY=sk-your-key
GEMINI_API_KEY=your-key
ANTHROPIC_API_KEY=sk-ant-your-key

# n8n
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme
N8N_ENCRYPTION_KEY="replace-with-32+char-random-string"
WEBHOOK_URL=http://n8n:5678
GENERIC_TIMEZONE=Asia/Seoul
TZ=Asia/Seoul

# Host -> llm-proxy
LLM_PROXY_URL=http://localhost:8000
# Shared internal auth token (Next.js/agent -> llm-proxy)
LLM_PROXY_INTERNAL_TOKEN="change-this-in-local"
# Temporary bypass for backward-compat endpoints (recommended: empty once n8n header is wired)
LLM_PROXY_AUTH_BYPASS_PATHS="/api/hermes/daily-briefing"
LLM_PROXY_RATE_LIMIT_ENABLED=true
LLM_PROXY_RATE_LIMIT_RPM=240
LLM_PROXY_MAX_BODY_BYTES=1048576

# Google Calendar (Read-Only for Morpheus)
GOOGLE_CALENDAR_READONLY_ENABLED=false
GOOGLE_CALENDAR_CLIENT_ID=""
GOOGLE_CALENDAR_CLIENT_SECRET=""
GOOGLE_CALENDAR_REFRESH_TOKEN=""
GOOGLE_CALENDAR_ID="primary"
GOOGLE_CALENDAR_TIMEZONE="Asia/Seoul"
GOOGLE_CALENDAR_MAX_RESULTS=10
GOOGLE_CALENDAR_MASK_SENSITIVE=true
