# Public UI values
NEXT_PUBLIC_DASHBOARD_TITLE="Nanoclaw Air-Gapped Agent Dashboard"
NEXT_PUBLIC_DEFAULT_AGENT_ID="owl"

# Proxy router behavior: store | forward
PROXY_MODE="store"

# SQLite DB path (relative to project root unless absolute)
SQLITE_PATH="./shared_data/agent_router.db"

# n8n webhook URLs
# - INTERNAL: used by containers (llm-proxy -> n8n)
# - HOST: used by host processes (Next.js server route -> n8n)
N8N_WEBHOOK_URL_INTERNAL="http://n8n:5678/webhook/hermes-trend"
N8N_WEBHOOK_URL_HOST="http://localhost:5678/webhook/hermes-trend"
# Backward compatibility fallback
N8N_WEBHOOK_URL="http://localhost:5678/webhook/hermes-trend"
N8N_WEBHOOK_AUTH_TOKEN=""
# Optional: local n8n trend workflow key (used by n8n HTTP Request node)
TAVILY_API_KEY="tvly-your-key"
# Agents allowed to trigger Tavily/n8n web search (comma-separated)
AGENT_WEB_SEARCH_TARGETS="dolphin,ace"
# Source trust gate for web search context
WEB_SEARCH_ALLOWED_DOMAINS="openai.com,anthropic.com,deepmind.google,huggingface.co,tldr.tech,dev.to,lobste.rs,reuters.com,bloomberg.com,nytimes.com,bbc.com,kdi.re.kr,sap.com,toss.tech,tech.kakao.com,d2.naver.com,yozm.wishket.com,techblog.woowahan.com,tech.inflab.com,go.kr"
WEB_SEARCH_MIN_TRUSTED_SOURCES=2
WEB_SEARCH_ENFORCE_MIN_TRUSTED_SOURCES=true

# LLM API Keys (llm-proxy 컨테이너에서 사용)
OPENAI_API_KEY=sk-your-key
GEMINI_API_KEY=your-key
ANTHROPIC_API_KEY=sk-ant-your-key

# n8n
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme
N8N_ENCRYPTION_KEY="replace-with-32+char-random-string"
WEBHOOK_URL=http://n8n:5678
GENERIC_TIMEZONE=Asia/Seoul
TZ=Asia/Seoul
# n8n -> llm-proxy webhook signing (HMAC SHA-256)
N8N_WEBHOOK_SIGNING_SECRET="replace-with-random-32+chars"
N8N_WEBHOOK_SIGNATURE_REQUIRED=true
N8N_WEBHOOK_MAX_SKEW_SEC=300

# Host -> llm-proxy
LLM_PROXY_URL=http://localhost:8000
# Shared internal auth token (Next.js/agent -> llm-proxy)
LLM_PROXY_INTERNAL_TOKEN="change-this-in-local"
# Optional bypass paths for emergency use only (comma-separated). Keep empty in normal operation.
LLM_PROXY_AUTH_BYPASS_PATHS=""
LLM_PROXY_RATE_LIMIT_ENABLED=true
LLM_PROXY_RATE_LIMIT_RPM=240
LLM_PROXY_MAX_BODY_BYTES=1048576

# Telegram Bridge (agent별 봇 토큰 + allowlist)
TELEGRAM_BRIDGE_ENABLED=false
TELEGRAM_ENABLED_AGENTS="ace"
TELEGRAM_POLL_INTERVAL_SEC=6
TELEGRAM_MAX_UPDATES_PER_POLL=20
TELEGRAM_HTTP_TIMEOUT_SEC=30

# Shared cross-channel history (web <-> telegram)
AGENT_SHARED_HISTORY_ENABLED=true
AGENT_SHARED_HISTORY_TARGETS="ace"
AGENT_HISTORY_DB_PATH="/app/shared_data/agent_comms/history/agent_history.sqlite3"
AGENT_HISTORY_MAX_CONTEXT_MESSAGES=20
AGENT_HISTORY_MAX_STORED_MESSAGES=300
AGENT_HISTORY_MAX_MESSAGE_CHARS=4000
ACE_SHARED_USER_ID="owner"

# Stage 1: Morpheus 파일럿
TELEGRAM_BOT_TOKEN_ACE=""
TELEGRAM_ALLOWED_CHAT_IDS_ACE=""
TELEGRAM_ALLOWED_COMMANDS_ACE="read,summary,chat"
TELEGRAM_SHARED_USER_ID_ACE="owner"

# Stage 2: Clio / Hermes 확장
TELEGRAM_BOT_TOKEN_OWL=""
TELEGRAM_ALLOWED_CHAT_IDS_OWL=""
TELEGRAM_ALLOWED_COMMANDS_OWL="read,summary,chat"
TELEGRAM_SHARED_USER_ID_OWL=""

TELEGRAM_BOT_TOKEN_DOLPHIN=""
TELEGRAM_ALLOWED_CHAT_IDS_DOLPHIN=""
TELEGRAM_ALLOWED_COMMANDS_DOLPHIN="read,summary,trend,chat"
TELEGRAM_SHARED_USER_ID_DOLPHIN=""

# NotebookLM Connector (Clio 수동 승인 업로드)
NOTEBOOKLM_CONNECTOR_ENABLED=false
NOTEBOOKLM_CONNECTOR_URL=""
NOTEBOOKLM_CONNECTOR_API_KEY=""
NOTEBOOKLM_CONNECTOR_TIMEOUT_SEC=30

# Google Calendar (Read-Only for Morpheus)
GOOGLE_CALENDAR_READONLY_ENABLED=false
GOOGLE_CALENDAR_CLIENT_ID=""
GOOGLE_CALENDAR_CLIENT_SECRET=""
GOOGLE_CALENDAR_REFRESH_TOKEN=""
GOOGLE_CALENDAR_ID="primary"
GOOGLE_CALENDAR_TIMEZONE="Asia/Seoul"
GOOGLE_CALENDAR_MAX_RESULTS=10
GOOGLE_CALENDAR_MASK_SENSITIVE=true

# Memory update guard
MEMORY_UPDATE_REQUIRE_APPROVAL_ON_EXTERNAL=true
MEMORY_QUARANTINE_DIR="/app/shared_data/agent_comms/quarantine"
