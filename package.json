{
  "name": "airgapped-agent-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit",
    "lint:next": "next lint",
    "git:guard": "bash scripts/prepush-guard.sh",
    "git:hooks": "git config core.hooksPath .githooks",
    "security:rotate-internal": "bash scripts/security/rotate-internal-secrets.sh",
    "n8n:test-search": "bash scripts/n8n/test-local-web-search.sh",
    "n8n:test-briefing": "bash scripts/n8n/test-hermes-daily-briefing.sh",
    "thread:finish": "bash scripts/threads/finish-thread.sh",
    "release:merge-order": "bash scripts/release-captain/merge-in-order.sh",
    "watch:codex:once": "bash scripts/release-captain/watch-codex-pipeline.sh --once",
    "watch:codex:start": "bash scripts/release-captain/watch-daemon.sh start",
    "watch:codex:stop": "bash scripts/release-captain/watch-daemon.sh stop",
    "watch:codex:status": "bash scripts/release-captain/watch-daemon.sh status",
    "watch:codex:logs": "bash scripts/release-captain/watch-daemon.sh logs"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.0",
    "better-sqlite3": "^11.7.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "next": "^15.5.12",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.1",
    "eslint-config-next": "^15.5.12",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
